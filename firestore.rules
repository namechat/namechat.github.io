rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isThreadMember(threadId) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/threads/$(threadId)).data.members;
    }

    match /users/{uid} {
      allow get: if signedIn();
      allow list: if false;
      allow create, update: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.username is string
        && request.resource.data.username.size() >= 3
        && request.resource.data.username.size() <= 24;
      allow delete: if false;
    }

    match /usernames/{username} {
      allow get: if signedIn();
      allow create: if signedIn()
        && !exists(/databases/$(database)/documents/usernames/$(username))
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username == username;
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username == username;
      allow delete: if false;
    }

    match /threads/{threadId} {
      allow get, list: if signedIn() && request.auth.uid in resource.data.members;
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members.size() == 2;
      allow update: if signedIn()
        && request.auth.uid in resource.data.members
        && request.resource.data.members == resource.data.members;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isThreadMember(threadId);
        allow create: if isThreadMember(threadId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000;
        allow update, delete: if false;
      }
    }
  }
}
